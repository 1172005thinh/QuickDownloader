<Window x:Class="QuickDownloader.GUI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:util="clr-namespace:QuickDownloader.GUI.Utilities"
        mc:Ignorable="d"
        Title="Quick Downloader" 
        Height="600" Width="800"
        MinHeight="400" MinWidth="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize">

    <WindowChrome.WindowChrome>
        <!-- ResizeBorderThickness should cover the transparent shadow margin (10px) -->
        <WindowChrome CaptionHeight="40" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="14" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Header Button Style -->
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource AppRegularTextBrush}"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppSecondaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource HeaderButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppPrimaryBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Main Window Outline Style -->
        <Style x:Key="MainBorderStyle" TargetType="Border">
            <!-- Default (inactive) border color -->
            <Setter Property="BorderBrush" Value="{DynamicResource AppSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
            <Style.Triggers>
                <!-- Highlight border when window is focused/active -->
                <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AppPrimaryBrush}" />
                </DataTrigger>
                <!-- Remove rounded corners and border when maximized to fit screen perfectly -->
                <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                    <Setter Property="CornerRadius" Value="0" />
                    <Setter Property="BorderThickness" Value="0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Main Grid Shadow Margin Style -->
        <Style x:Key="MainGridStyle" TargetType="Grid">
            <Setter Property="Margin" Value="15" />
            <Style.Triggers>
                <!-- Remove shadow margin when maximized -->
                <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                    <Setter Property="Margin" Value="0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Style="{StaticResource MainGridStyle}">
        <Border x:Name="MainBorder" Style="{StaticResource MainBorderStyle}">
            <!-- Drop Shadow Effect -->
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="10" Opacity="0.5" Direction="225" />
            </Border.Effect>

            <Grid>
                <!-- Mask border to enforce rounded corners clipping on inner elements -->
                <Border x:Name="Mask" Background="White" CornerRadius="{Binding CornerRadius, ElementName=MainBorder}" />
                
                <Grid>
                    <Grid.OpacityMask>
                        <VisualBrush Visual="{Binding ElementName=Mask}" />
                    </Grid.OpacityMask>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Background="{DynamicResource AppBackgroundBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>

                        <!-- App Icon -->
                        <Image Grid.Column="0" util:IconHelper.IconName="app_icon_16.ico" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- App Title -->
                        <TextBlock Grid.Column="1" Text="Quick Downloader" Style="{DynamicResource Font_M_R}" VerticalAlignment="Center" Margin="5,0,0,0"/>

                        <!-- Window Controls -->
                        <Button Grid.Column="3" Style="{StaticResource HeaderButtonStyle}" ToolTip="Minimize" Click="MinimizeButton_Click">
                            <Image util:IconHelper.IconName="minimize_button_icon_16.ico" Width="16" Height="16"/>
                        </Button>
                        
                        <Button Grid.Column="4" Style="{StaticResource HeaderButtonStyle}" ToolTip="Maximize" Click="MaximizeButton_Click">
                            <Image util:IconHelper.IconName="maximize_button_icon_16.ico" Width="16" Height="16"/>
                        </Button>
                        
                        <Button Grid.Column="5" Style="{StaticResource CloseButtonStyle}" ToolTip="Close" Click="CloseButton_Click">
                            <Image util:IconHelper.IconName="close_button_icon_16.ico" Width="16" Height="16"/>
                        </Button>
                    </Grid>

                    <!-- Main Content Area -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Sidebar Placeholder -->
                        <Border Grid.Column="0" Background="{DynamicResource AppSecondaryBrush}">
                            <!-- Options 2 will implement the sidebar elements here -->
                        </Border>

                        <!-- Content Placeholder -->
                        <Border Grid.Column="1" Background="{DynamicResource AppBackgroundBrush}">
                            <!-- Pages will be loaded here -->
                        </Border>
                    </Grid>

                    <!-- Footer -->
                    <Grid Grid.Row="2" Background="{DynamicResource AppSecondaryBrush}">
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>