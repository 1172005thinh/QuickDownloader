<Window x:Class="QuickDownloader.GUI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:util="clr-namespace:QuickDownloader.GUI.Utilities"
        mc:Ignorable="d"
        Title="Quick Downloader" 
        Height="600" Width="800"
        MinHeight="400" MinWidth="600"
        WindowStyle="None"
        Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}"
        ResizeMode="CanResize">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="5" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Header Button Style -->
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource HeaderButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF0000"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>

            <!-- App Icon -->
            <Image Grid.Column="0" util:IconHelper.IconName="app_icon_16.ico" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <!-- App Title -->
            <TextBlock Grid.Column="1" Text="Quick Downloader" FontFamily="Segoe UI" FontSize="16" VerticalAlignment="Center" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" Margin="5,0,0,0"/>

            <!-- Window Controls -->
            <Button Grid.Column="3" Style="{StaticResource HeaderButtonStyle}" ToolTip="Minimize" Click="MinimizeButton_Click">
                <Image util:IconHelper.IconName="minimize_button_icon_16.ico" Width="16" Height="16"/>
            </Button>
            
            <Button Grid.Column="4" Style="{StaticResource HeaderButtonStyle}" ToolTip="Maximize" Click="MaximizeButton_Click">
                <Image util:IconHelper.IconName="maximize_button_icon_16.ico" Width="16" Height="16"/>
            </Button>
            
            <Button Grid.Column="5" Style="{StaticResource CloseButtonStyle}" ToolTip="Close" Click="CloseButton_Click">
                <Image util:IconHelper.IconName="close_button_icon_16.ico" Width="16" Height="16"/>
            </Button>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar Placeholder -->
            <Border Grid.Column="0" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                <!-- Options 2 will implement the sidebar elements here -->
            </Border>

            <!-- Content Placeholder -->
            <Border Grid.Column="1" Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}">
                <!-- Pages will be loaded here -->
            </Border>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="2" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
        </Grid>
    </Grid>
</Window>